{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-sdd.local/schemas/pattern.schema.json",
  "description": "Atlas curated Pattern frontmatter, transcribing §32.1, §10.1–§10.2, §14.9, and §34.4.",
  "type": "object",
  "properties": {
    "id": {"$ref": "#/$defs/patternId"},
    "type": {"const": "pattern"},
    "title": {"type": "string"},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "concept_edges": {"type": "array", "items": {"$ref": "#/$defs/conceptEdge"}},
    "formerly": {"type": "array", "items": {"$ref": "#/$defs/patternId"}}
  },
  "required": ["id", "type", "title"],
  "additionalProperties": false,
  "$defs": {
    "patternId": {"type": "string", "pattern": "^pattern:[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "regionId": {"type": "string", "pattern": "^(?:concept|pattern|zone):[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "conceptEdge": {
      "type": "object",
      "properties": {
        "to": {"$ref": "#/$defs/regionId"},
        "role": {
          "type": "string",
          "enum": ["related_to", "prerequisite_of", "extends", "contradicts", "loads"],
          "description": "Pattern-source authored roles transcribed verbatim from §32.1 and the §10.2 matrix."
        },
        "weight": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Authored edge-weight hypotheses transcribed verbatim from §14.9."
        }
      },
      "required": ["to", "role"],
      "additionalProperties": false
    }
  }
}
