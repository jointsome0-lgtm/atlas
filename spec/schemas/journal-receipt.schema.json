{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-sdd.local/schemas/journal-receipt.schema.json",
  "description": "Atlas receipts.jsonl content-free receipt row, transcribing the closed §33.2 idempotency-key, marker, and date contract.",
  "type": "object",
  "properties": {
    "intake": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*#[0-9]+$"},
    "marker": {"$ref": "#/$defs/marker"},
    "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"}
  },
  "required": ["intake", "marker", "date"],
  "additionalProperties": false,
  "$defs": {
    "marker": {
      "type": "string",
      "enum": ["opened", "processed"],
      "description": "Receipt markers transcribed verbatim from §33.2."
    }
  }
}
