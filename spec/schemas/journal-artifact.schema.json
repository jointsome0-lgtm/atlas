{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-sdd.local/schemas/journal-artifact.schema.json",
  "description": "Atlas artifacts.jsonl row, transcribing §9.6, §33.2 provenance, and §32.6 sensitivity.",
  "type": "object",
  "properties": {
    "id": {"type": "string", "pattern": "^artifact:[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "type": {"type": "string"},
    "path": {"type": "string"},
    "observed_at": {"$ref": "#/$defs/date"},
    "summary": {"type": "string"},
    "touches": {"type": "array", "items": {"$ref": "#/$defs/regionId"}},
    "supports_state_updates": {"type": "array", "items": {"$ref": "#/$defs/regionId"}},
    "evidence_strength": {"$ref": "#/$defs/evidenceStrength"},
    "probe": {"type": "string", "pattern": "^probe:[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "intake": {"$ref": "#/$defs/intakeKey"},
    "sensitivity": {"$ref": "#/$defs/sensitivity"}
  },
  "required": ["id", "type", "path", "observed_at", "summary", "touches", "supports_state_updates", "evidence_strength"],
  "additionalProperties": false,
  "$defs": {
    "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "regionId": {"type": "string", "pattern": "^(?:concept|pattern|zone):[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "intakeKey": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*#[0-9]+$"},
    "evidenceStrength": {
      "type": "string",
      "enum": ["noticed", "read", "summarized", "applied", "explained", "reviewed", "performed", "drilled"],
      "description": "Artifact evidence strengths transcribed verbatim from §9.6."
    },
    "sensitivity": {
      "type": "string",
      "enum": ["medical"],
      "description": "Sensitivity classes transcribed verbatim from §32.6 and §33.2."
    }
  }
}
