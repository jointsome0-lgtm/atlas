{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-sdd.local/schemas/run-manifest.schema.json",
  "description": "Closed per-run audit manifest for model-assisted agent runs, transcribing §17.6 (#41) and the exact §17.7 runner-protocol pin (#46). Written whole at run close by the runner; no prompt text, no instance-content hashes, no free text — refs and codes are single tokens, warnings are slug reason codes (§24.4).",
  "type": "object",
  "properties": {
    "format": {
      "const": "run-manifest"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "run_id": {
      "type": "string",
      "pattern": "^run:[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$"
    },
    "role": {
      "type": "string",
      "enum": [
        "plan-importer",
        "artifact-observer",
        "field-cartographer",
        "state-auditor"
      ]
    },
    "model": {
      "$ref": "#/$defs/model"
    },
    "engine_revision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "runner_version": {
      "type": "string",
      "pattern": "^\\S+$"
    },
    "runner_protocol": {
      "$ref": "#/$defs/runnerProtocol"
    },
    "prompt_bundle": {
      "$ref": "#/$defs/promptBundle"
    },
    "inputs": {
      "$ref": "#/$defs/inputs"
    },
    "budget": {
      "$ref": "#/$defs/budget"
    },
    "timings": {
      "$ref": "#/$defs/timings"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "processed",
        "aborted"
      ]
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+:\\S+$"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/slug"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+:\\S+$"
      }
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "medical"
      ]
    }
  },
  "required": [
    "format",
    "version",
    "run_id",
    "role",
    "model",
    "engine_revision",
    "runner_version",
    "runner_protocol",
    "prompt_bundle",
    "inputs",
    "budget",
    "timings",
    "outcome",
    "outputs",
    "warnings",
    "decisions"
  ],
  "additionalProperties": false,
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "instant": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "runnerProtocol": {
      "type": "object",
      "description": "Exact reusable process/isolation pin owned by §17.7 (#46).",
      "properties": {
        "version": {
          "type": "integer",
          "const": 1
        },
        "commit": {
          "type": "string",
          "const": "be83303bfbe3a1523c72ebaa3f0baa03389c5832"
        }
      },
      "required": [
        "version",
        "commit"
      ],
      "additionalProperties": false
    },
    "model": {
      "type": "object",
      "properties": {
        "provider": {
          "$ref": "#/$defs/slug"
        },
        "id": {
          "type": "string",
          "pattern": "^\\S+$"
        },
        "parameters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "$ref": "#/$defs/slug"
              },
              "value": {
                "type": "string",
                "pattern": "^\\S*$"
              }
            },
            "required": [
              "name",
              "value"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "provider",
        "id",
        "parameters"
      ],
      "additionalProperties": false
    },
    "promptBundle": {
      "type": "object",
      "properties": {
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "$ref": "#/$defs/slug"
              },
              "version": {
                "type": "string",
                "pattern": "^\\S+$"
              },
              "sha256": {
                "$ref": "#/$defs/sha256"
              }
            },
            "required": [
              "id",
              "version",
              "sha256"
            ],
            "additionalProperties": false
          }
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "required": [
        "components",
        "sha256"
      ],
      "additionalProperties": false
    },
    "inputs": {
      "type": "object",
      "properties": {
        "included": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "pattern": "\\S"
              },
              "bytes": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": [
              "path",
              "bytes"
            ],
            "additionalProperties": false
          }
        },
        "unavailable": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "pattern": "\\S"
              },
              "reason": {
                "type": "string",
                "enum": [
                  "excluded",
                  "out-of-row",
                  "missing",
                  "over-budget"
                ]
              }
            },
            "required": [
              "path",
              "reason"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "included",
        "unavailable"
      ],
      "additionalProperties": false
    },
    "budget": {
      "type": "object",
      "properties": {
        "model_calls": {
          "type": "integer",
          "minimum": 0
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "input_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "input_entries": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "model_calls",
        "timeout_seconds",
        "input_bytes",
        "input_entries"
      ],
      "additionalProperties": false
    },
    "timings": {
      "type": "object",
      "properties": {
        "started_at": {
          "$ref": "#/$defs/instant"
        },
        "ended_at": {
          "$ref": "#/$defs/instant"
        }
      },
      "required": [
        "started_at",
        "ended_at"
      ],
      "additionalProperties": false
    }
  }
}
