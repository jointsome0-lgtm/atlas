{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-sdd.local/schemas/atlas-graph.schema.json",
  "description": "Atlas graph and redacted graph emission, transcribing §10.1–§10.4, §14.9, §20, §25.7, and §32.6.",
  "type": "object",
  "properties": {
    "format": {"const": "atlas-graph"},
    "version": {"type": "integer", "const": 1},
    "generated_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "nodes": {"type": "array", "items": {"$ref": "#/$defs/node"}},
    "edges": {"type": "array", "items": {"$ref": "#/$defs/edge"}},
    "trails": {"type": "array"},
    "state": {"type": "object"},
    "influence": {"type": "object"},
    "frontier": {"type": "array"},
    "projections": {"type": "object", "additionalProperties": {"type": "string"}},
    "withheld": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}}
  },
  "required": ["format", "version", "nodes", "edges", "trails", "state", "influence", "frontier", "projections"],
  "additionalProperties": true,
  "$defs": {
    "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "nodeId": {"type": "string", "pattern": "^(?:(?:plan|concept|material|direction|suggested-route|personal-trail|trail-segment|artifact|encounter|question|probe|zone|pattern):[a-z0-9]+(?:-[a-z0-9]+)*|part:[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*)$"},
    "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "nodeType": {
      "type": "string",
      "enum": ["plan", "concept", "material", "material_part", "direction", "suggested_route", "personal_trail", "trail_segment", "artifact", "encounter", "question", "probe", "zone", "pattern"],
      "description": "Closed node types transcribed verbatim from §10.1."
    },
    "edgeType": {
      "type": "string",
      "enum": ["related_to", "prerequisite_of", "extends", "implements", "contradicts", "explains", "demonstrates", "critiques", "mentions", "loads", "has_part", "overall_concept", "supports", "part_of_direction", "step_of_route", "suggested_next", "visited", "moved_to", "via", "pulled_by", "produced_artifact", "updates_state", "influences", "probed_by", "primary_for", "supporting_for"],
      "description": "Closed edge types transcribed verbatim from §10.2."
    },
    "authoredRole": {
      "type": "string",
      "enum": ["related_to", "prerequisite_of", "extends", "implements", "contradicts", "explains", "demonstrates", "critiques", "mentions", "loads"],
      "description": "Union of authored concept_edges roles transcribed from §9.1, §9.3, §32.1, and the §10.2 matrix."
    },
    "edgeWeight": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Authored edge-weight hypotheses transcribed verbatim from §14.9."
    },
    "emittedEdgeWeight": {
      "type": "string",
      "enum": ["low", "medium", "high", "unassessed"],
      "description": "Emitted edge weights transcribed verbatim from §14.9."
    },
    "lifecycleStatus": {
      "type": "string",
      "enum": ["active", "archived"],
      "description": "Material and Probe lifecycle values transcribed verbatim from §9.2 and §9.11."
    },
    "routeStatus": {
      "type": "string",
      "enum": ["available", "hidden", "partially_followed", "ignored", "archived"],
      "description": "SuggestedRoute states transcribed verbatim from §9.4."
    },
    "field": {
      "type": "string",
      "enum": ["knowledge", "body"],
      "description": "Field slugs transcribed verbatim from the §10.1 registry."
    },
    "materialKind": {
      "type": "string",
      "enum": ["article", "docs", "paper", "book", "repo", "video", "course", "spec", "tutorial", "internal"],
      "description": "Material kinds transcribed verbatim from §9.2."
    },
    "evidenceStrength": {
      "type": "string",
      "enum": ["noticed", "read", "summarized", "applied", "explained", "reviewed", "performed", "drilled"],
      "description": "Artifact evidence strengths transcribed verbatim from §9.6."
    },
    "encounterDepth": {
      "type": "string",
      "enum": ["skim", "read", "summarized", "applied", "taught"],
      "description": "Encounter depths transcribed verbatim from §9.7."
    },
    "idPrefixes": {
      "type": "object",
      "properties": {
        "concept": {"const": "concept"},
        "material": {"const": "material"},
        "part": {"const": "material_part"},
        "direction": {"const": "direction"},
        "suggested-route": {"const": "suggested_route"},
        "trail-segment": {"const": "trail_segment"},
        "personal-trail": {"const": "personal_trail"},
        "artifact": {"const": "artifact"},
        "encounter": {"const": "encounter"},
        "question": {"const": "question"},
        "probe": {"const": "probe"},
        "plan": {"const": "plan"},
        "zone": {"const": "zone"},
        "pattern": {"const": "pattern"}
      },
      "required": ["concept", "material", "part", "direction", "suggested-route", "trail-segment", "personal-trail", "artifact", "encounter", "question", "probe", "plan", "zone", "pattern"],
      "additionalProperties": false
    },
    "endpointRules": {
      "type": "object",
      "properties": {
        "related_to": {"$ref": "#/$defs/endConceptConcept"},
        "prerequisite_of": {"$ref": "#/$defs/endConceptPartConcept"},
        "extends": {"$ref": "#/$defs/endConceptPartConcept"},
        "implements": {"$ref": "#/$defs/endPartConcept"},
        "contradicts": {"$ref": "#/$defs/endConceptPartConcept"},
        "explains": {"$ref": "#/$defs/endPartConcept"},
        "demonstrates": {"$ref": "#/$defs/endPartConcept"},
        "critiques": {"$ref": "#/$defs/endPartConcept"},
        "mentions": {"$ref": "#/$defs/endPartConcept"},
        "loads": {"$ref": "#/$defs/endPatternZone"},
        "supports": {"$ref": "#/$defs/endMaterialMaterial"},
        "has_part": {"$ref": "#/$defs/endMaterialPart"},
        "overall_concept": {"$ref": "#/$defs/endMaterialConcept"},
        "part_of_direction": {"$ref": "#/$defs/endConceptDirection"},
        "step_of_route": {"$ref": "#/$defs/endConceptRoute"},
        "suggested_next": {"$ref": "#/$defs/endConceptConcept"},
        "probed_by": {"$ref": "#/$defs/endRegionProbe"},
        "pulled_by": {"$ref": "#/$defs/endRegionQuestion"},
        "visited": {"$ref": "#/$defs/endEncounterMaterial"},
        "influences": {"$ref": "#/$defs/endArtifactRegion"},
        "updates_state": {"$ref": "#/$defs/endArtifactRegion"},
        "moved_to": {"$ref": "#/$defs/endConceptConcept"},
        "via": {"$ref": "#/$defs/endTrailMaterial"},
        "produced_artifact": {"$ref": "#/$defs/endTrailArtifact"},
        "primary_for": {"$ref": "#/$defs/endMaterialContext"},
        "supporting_for": {"$ref": "#/$defs/endMaterialContext"}
      },
      "additionalProperties": false
    },
    "endConceptConcept": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["concept", "pattern"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["concept", "pattern"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endConceptPartConcept": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["concept", "material_part", "pattern"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["concept", "pattern"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endPartConcept": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["material_part"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["concept", "pattern"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endPatternZone": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["pattern"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["zone"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endMaterialMaterial": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["material", "material_part"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["material", "material_part"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endMaterialPart": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["material"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["material_part"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endMaterialConcept": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["material"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["concept", "pattern"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endConceptDirection": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["concept", "pattern"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["direction"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endConceptRoute": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["concept", "pattern"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["suggested_route"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endRegionProbe": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["concept", "pattern", "zone"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["probe"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endRegionQuestion": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["concept", "pattern", "zone"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["question"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endEncounterMaterial": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["encounter"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["material", "material_part"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endArtifactRegion": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["artifact"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["concept", "pattern", "zone"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endTrailMaterial": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["trail_segment"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["material", "material_part"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endTrailArtifact": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["trail_segment"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["artifact"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endMaterialContext": {"$ref": "#/$defs/endpointTemplate", "properties": {"source": {"enum": ["material", "material_part"], "description": "Source kinds transcribed from the §10.2 matrix."}, "target": {"enum": ["suggested_route", "question", "trail_segment"], "description": "Target kinds transcribed from the §10.2 matrix."}}},
    "endpointTemplate": {"type": "object", "properties": {"source": {"type": "string"}, "target": {"type": "string"}}, "required": ["source", "target"], "additionalProperties": false},
    "node": {
      "type": "object",
      "properties": {
        "id": {"$ref": "#/$defs/nodeId"},
        "type": {"$ref": "#/$defs/nodeType"},
        "title": {"type": "string"},
        "fields": {"type": "array", "items": {"$ref": "#/$defs/field"}, "uniqueItems": true},
        "formerly": {"type": "array", "items": {"$ref": "#/$defs/nodeId"}},
        "sensitivity": {"type": "string", "enum": ["medical"], "description": "Sensitivity classes transcribed verbatim from §32.6 and §33.2."},
        "aliases": {"type": "array", "items": {"type": "string"}},
        "notes": {"type": "string"},
        "material": {"type": "string", "pattern": "^material:[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "kind": {"type": "string"},
        "url": {"type": "string"},
        "status": {"type": "string"},
        "source_plan": {"type": "string", "pattern": "^plan:[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "attractor": {"type": "string"},
        "text": {"type": "string"},
        "created_at": {"$ref": "#/$defs/date"},
        "source": {},
        "body": {"type": "string"},
        "path": {"type": "string"},
        "observed_at": {"$ref": "#/$defs/date"},
        "summary": {"type": "string"},
        "evidence_strength": {"$ref": "#/$defs/evidenceStrength"},
        "probe": {"type": "string", "pattern": "^probe:[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "date": {"$ref": "#/$defs/date"},
        "target": {"$ref": "#/$defs/nodeId"},
        "depth": {"$ref": "#/$defs/encounterDepth"},
        "mode": {"type": "string"},
        "context": {},
        "direction": {"type": "string", "pattern": "^direction:[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "from": {},
        "to": {"$ref": "#/$defs/nodeId"},
        "via": {"type": "array", "items": {"$ref": "#/$defs/nodeId"}},
        "reason": {"type": "string"},
        "resulting_questions": {"type": "array", "items": {"type": "string", "pattern": "^question:[a-z0-9]+(?:-[a-z0-9]+)*$"}}
      },
      "required": ["id", "type", "title", "fields"],
      "additionalProperties": true,
      "allOf": [
        {"if": {"properties": {"type": {"enum": ["concept", "pattern"], "description": "Concept-kind rows transcribed from the §10.4 per-kind table."}}, "required": ["type"]}, "then": {"required": ["aliases"]}},
        {"if": {"properties": {"type": {"const": "zone"}}, "required": ["type"]}, "then": {"required": ["notes"]}},
        {"if": {"properties": {"type": {"const": "material_part"}}, "required": ["type"]}, "then": {"required": ["material"]}},
        {"if": {"properties": {"type": {"const": "material"}}, "required": ["type"]}, "then": {"properties": {"kind": {"$ref": "#/$defs/materialKind"}, "status": {"$ref": "#/$defs/lifecycleStatus"}}, "required": ["kind", "url", "status"]}},
        {"if": {"properties": {"type": {"const": "suggested_route"}}, "required": ["type"]}, "then": {"properties": {"status": {"$ref": "#/$defs/routeStatus"}}, "required": ["status"]}},
        {"if": {"properties": {"type": {"const": "direction"}}, "required": ["type"]}, "then": {"properties": {"status": {"$ref": "#/$defs/lifecycleStatus"}}, "required": ["status", "attractor"]}},
        {"if": {"properties": {"type": {"const": "question"}}, "required": ["type"]}, "then": {"required": ["text", "created_at", "source"]}},
        {"if": {"properties": {"type": {"const": "probe"}}, "required": ["type"]}, "then": {"properties": {"status": {"$ref": "#/$defs/lifecycleStatus"}}, "required": ["status", "body"]}},
        {"if": {"properties": {"type": {"const": "artifact"}}, "required": ["type"]}, "then": {"required": ["kind", "path", "observed_at", "summary", "evidence_strength"]}},
        {"if": {"properties": {"type": {"const": "encounter"}}, "required": ["type"]}, "then": {"required": ["date", "target", "depth", "mode", "context"]}},
        {"if": {"properties": {"type": {"const": "trail_segment"}}, "required": ["type"]}, "then": {"required": ["date", "direction", "to", "via", "reason", "resulting_questions"]}},
        {"if": {"properties": {"type": {"const": "personal_trail"}}, "required": ["type"]}, "then": {"required": ["direction"]}}
      ]
    },
    "edge": {
      "type": "object",
      "properties": {
        "source": {"$ref": "#/$defs/nodeId"},
        "target": {"$ref": "#/$defs/nodeId"},
        "type": {"$ref": "#/$defs/edgeType"},
        "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/nodeId"}},
        "weight": {"$ref": "#/$defs/emittedEdgeWeight"},
        "order": {"type": "integer", "minimum": 1},
        "context": {"$ref": "#/$defs/nodeId"},
        "step": {"$ref": "#/$defs/nodeId"},
        "confidence": {"type": "string", "enum": ["unknown", "low", "medium", "high"], "description": "Confidence annotations transcribe §14.2."},
        "created_by": {"type": "string"},
        "created_at": {"$ref": "#/$defs/date"},
        "note": {"type": "string"}
      },
      "required": ["source", "target", "type", "provenance"],
      "additionalProperties": true,
      "allOf": [
        {"if": {"properties": {"type": {"enum": ["related_to", "prerequisite_of", "extends", "implements", "contradicts", "explains", "demonstrates", "critiques", "mentions", "loads", "supports"], "description": "Authored edge species requiring an emitted §14.9 fold weight, transcribed from §10.2–§10.3."}}, "required": ["type"]}, "then": {"required": ["weight"]}},
        {"if": {"properties": {"type": {"const": "step_of_route"}}, "required": ["type"]}, "then": {"required": ["order"]}},
        {"if": {"properties": {"type": {"const": "suggested_next"}}, "required": ["type"]}, "then": {"required": ["context"]}},
        {"if": {"properties": {"type": {"enum": ["primary_for", "supporting_for"], "description": "Contextual material-role edge types transcribed from §10.2–§10.3."}, "target": {"pattern": "^suggested-route:"}}, "required": ["type", "target"]}, "then": {"required": ["step"]}}
      ]
    }
  }
}
