{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-sdd.local/schemas/journal-mapping-decision.schema.json",
  "description": "Atlas mapping-decisions.jsonl identity decision row, transcribing §21.3, §33.2, and §32.6.",
  "type": "object",
  "properties": {
    "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "target": {"type": "string", "pattern": "^.+ -> .+$"},
    "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "decision": {"$ref": "#/$defs/decision"},
    "intake": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*#[0-9]+$"},
    "sensitivity": {"$ref": "#/$defs/sensitivity"}
  },
  "required": ["date", "target", "evidence", "decision"],
  "additionalProperties": false,
  "$defs": {
    "decision": {
      "type": "string",
      "enum": ["confirmed", "rejected"],
      "description": "Identity decisions transcribed verbatim from §21.3."
    },
    "sensitivity": {
      "type": "string",
      "enum": ["medical"],
      "description": "Sensitivity classes transcribed verbatim from §32.6 and §33.2."
    }
  }
}
