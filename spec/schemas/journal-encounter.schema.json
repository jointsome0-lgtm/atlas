{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-sdd.local/schemas/journal-encounter.schema.json",
  "description": "Atlas encounters.jsonl row, transcribing §9.7, §33.2 provenance, and §32.6 sensitivity.",
  "type": "object",
  "properties": {
    "id": {"type": "string", "pattern": "^encounter:[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "date": {"$ref": "#/$defs/date"},
    "target": {"$ref": "#/$defs/materialId"},
    "depth": {"$ref": "#/$defs/encounterDepth"},
    "mode": {"$ref": "#/$defs/encounterMode"},
    "context": {
      "type": "object",
      "properties": {
        "question": {"type": "string", "pattern": "^question:[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "artifact": {"type": "string", "pattern": "^artifact:[a-z0-9]+(?:-[a-z0-9]+)*$"}
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "intake": {"$ref": "#/$defs/intakeKey"},
    "sensitivity": {"$ref": "#/$defs/sensitivity"}
  },
  "required": ["id", "date", "target", "depth", "mode"],
  "additionalProperties": false,
  "$defs": {
    "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "materialId": {"type": "string", "pattern": "^(?:material:[a-z0-9]+(?:-[a-z0-9]+)*|part:[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*)$"},
    "intakeKey": {"type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9-]+#[0-9]+$"},
    "encounterDepth": {
      "type": "string",
      "enum": ["skim", "read", "summarized", "applied", "taught"],
      "description": "Encounter depths transcribed verbatim from §9.7."
    },
    "encounterMode": {
      "type": "string",
      "enum": ["plan-driven", "question-driven", "artifact-driven", "background"],
      "description": "Encounter modes transcribed verbatim from the §9.7 record shape."
    },
    "sensitivity": {
      "type": "string",
      "enum": ["medical"],
      "description": "Sensitivity classes transcribed verbatim from §32.6 and §33.2."
    }
  }
}
