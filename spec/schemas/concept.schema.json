{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-sdd.local/schemas/concept.schema.json",
  "description": "Atlas curated Concept frontmatter, transcribing §9.1, §10.1, §14.9, §33.3, and §34.4.",
  "type": "object",
  "properties": {
    "id": {"type": "string", "pattern": "^concept:[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "type": {"const": "concept"},
    "title": {"type": "string"},
    "updated": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "related_concepts": {"type": "array", "items": {"$ref": "#/$defs/conceptId"}},
    "concept_edges": {"type": "array", "items": {"$ref": "#/$defs/conceptEdge"}},
    "formerly": {"type": "array", "items": {"$ref": "#/$defs/conceptId"}},
    "sensitivity": {"$ref": "#/$defs/sensitivity"}
  },
  "required": ["id", "type", "title"],
  "additionalProperties": false,
  "$defs": {
    "conceptId": {"type": "string", "pattern": "^(?:concept|pattern):[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "conceptEdge": {
      "type": "object",
      "properties": {
        "to": {"$ref": "#/$defs/conceptId"},
        "role": {
          "type": "string",
          "enum": ["related_to", "prerequisite_of", "extends", "contradicts"],
          "description": "Concept-source authored roles transcribed verbatim from §9.1 and the §10.2 matrix."
        },
        "weight": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Authored edge-weight hypotheses transcribed verbatim from §14.9."
        }
      },
      "required": ["to", "role"],
      "additionalProperties": false
    },
    "sensitivity": {
      "type": "string",
      "enum": ["medical"],
      "description": "Sensitivity classes transcribed verbatim from §32.6 and §33.2."
    }
  }
}
